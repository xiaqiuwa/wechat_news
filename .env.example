# OpenAI 兼容中转站：密钥留空时只验证接口路径，并使用本地规则生成简版稿件
OPENAI_API_KEY=
OPENAI_BASE_URL=https://token.yiliao.hb.cn/v1
OPENAI_MODEL=gpt-5.5
# auto 会优先使用 Responses API，不兼容时自动改用 Chat Completions
OPENAI_API_MODE=auto

# 微信公众平台：不填写时只生成本地 HTML/Markdown，不上传
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_AUTHOR=每日要闻编辑部
WECHAT_AUTO_PUBLISH=false

# 每日运行设置
RUN_TIME=07:30
TIMEZONE=Asia/Shanghai
LOOKBACK_HOURS=30
MAX_ARTICLES=12
MIN_DOMESTIC=5
MIN_INTERNATIONAL=5

# 可选：固定封面图。不填写则自动生成“今日要闻”封面
WECHAT_COVER_PATH=

# 工作目录，默认 ./data
DATA_DIR=./data
